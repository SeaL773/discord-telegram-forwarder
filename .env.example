TG_BOT_TOKEN=replace-with-telegram-bot-token
BRIDGE_TOKEN=replace-with-bridge-bearer-token
ADMIN_CHAT_ID=replace-with-admin-alert-chat-id
# Used only by the optional .local/sync_topics.py helper.
TG_FORUM_CHAT_ID=replace-with-telegram-forum-chat-id
DISCORD_GUILD_ID=replace-with-discord-guild-id
# Compose env_file preserves a single $ literally in this setup; do not double it.
# After changing .env run `docker compose up -d`; `docker restart` does not reload it.
